<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Hardened-runtime entitlements for the bundled Python sidecar. A relocatable
     interpreter that dlopens third-party native libraries (OCP + its OCCT .dylibs,
     numpy/scipy) needs these, or macOS's hardened runtime / library validation kills
     it on a clean machine. Applied only when the app is signed (see build.yml). -->
<plist version="1.0">
<dict>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
